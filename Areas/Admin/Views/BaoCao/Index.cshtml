@model QLTCCN.Models.ViewModels.BaoCaoViewModel

<div class="container-fluid my-5">
    <h2 class="text-center fw-bold mb-4" style="color: #f0b90b;">📊 Dashboard Báo cáo (Admin)</h2>

    <!-- Bộ lọc và Mini Dashboard -->
    <div class="dashboard-container d-flex gap-4">
        <!-- Bộ lọc (bên trái, nhỏ gọn) -->
        <div class="filter-sidebar card shadow-lg border-0 hover-shadow" style="background-color: #1e1e1e; color: #f0f0f0; width: 25%; min-width: 220px; height: fit-content; position: sticky; top: 20px;">
            <div class="card-header py-2 bg-gradient" style="background: linear-gradient(45deg, #2B2B2B, #3C3C3C);">
                <h5 class="mb-0 text-gold fw-semibold"><i class="fas fa-calendar-alt me-2"></i>Bộ lọc</h5>
            </div>
            <div class="card-body p-3">
                <form asp-action="Index" method="get" class="d-flex flex-column gap-3">
                    <div class="form-group">
                        <label for="thang" class="form-label fw-semibold text-white mb-1">Tháng</label>
                        <select name="thang" id="thang" class="form-select bg-dark text-white border-gold rounded-pill px-2 py-1 shadow-sm transition-all">
                            @for (int i = 1; i <= 12; i++)
                            {
                                <option value="@i" selected="@(i == Model.Thang ? "selected" : null)">@i</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="nam" class="form-label fw-semibold text-white mb-1">Năm</label>
                        <select name="nam" id="nam" class="form-select bg-dark text-white border-gold rounded-pill px-2 py-1 shadow-sm transition-all">
                            @for (int i = DateTime.Now.Year - 5; i <= DateTime.Now.Year + 5; i++)
                            {
                                <option value="@i" selected="@(i == Model.Nam ? "selected" : null)">@i</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="userId" class="form-label fw-semibold text-white mb-1">Người dùng</label>
                        <select name="userId" id="userId" class="form-select bg-dark text-white border-gold rounded-pill px-2 py-1 shadow-sm transition-all">
                            @foreach (var user in ViewBag.Users)
                            {
                                <option value="@user.Id" selected="@(user.Id == ViewBag.SelectedUserId ? "selected" : null)">@user.FullName (@user.Email)</option>
                            }
                        </select>
                    </div>
                    <div class="form-group d-flex flex-column gap-2 mt-2">
                        <button type="submit" class="btn btn-gold rounded-pill px-3 py-1 fw-semibold hover-shadow transition-all">
                            <i class="fas fa-eye me-2"></i>Xem báo cáo
                        </button>
                        <a asp-area="Admin" asp-controller="Users" asp-action="Index" class="btn btn-gold rounded-pill px-3 py-1 fw-semibold hover-shadow transition-all">
                            <i class="fas fa-users me-2"></i>Xem người dùng
                        </a>
                        <button type="button" id="exportPdfBtn" class="btn btn-gold rounded-pill px-3 py-1 fw-semibold hover-shadow transition-all">
                            <i class="fas fa-file-pdf me-2"></i>Xuất PDF
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Nội dung Dashboard (bên phải) -->
        <div class="dashboard-content" style="width: 75%;">
            <!-- Mini Cards Tổng quan -->
            <div class="row g-3 mb-4">
                <div class="col-lg-4 col-md-6">
                    <div class="card mini-card shadow-lg border-0 hover-shadow animate-scale" style="background-color: #1e1e1e;">
                        <div class="card-body text-center p-3">
                            <i class="fas fa-money-bill-wave fa-2x mb-2 text-success"></i>
                            <h6 class="fw-semibold text-white mb-1">Thu nhập</h6>
                            <p class="fs-5 text-success mb-0">@Model.TongThuNhap.ToString("N0") VNĐ</p>
                            <a asp-area="Admin" asp-controller="GiaoDich" asp-action="Index" class="btn btn-gold btn-sm rounded-pill px-2 py-1 mt-2 hover-shadow transition-all">
                                <i class="fas fa-list"></i>
                            </a>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4 col-md-6">
                    <div class="card mini-card shadow-lg border-0 hover-shadow animate-scale" style="background-color: #1e1e1e;">
                        <div class="card-body text-center p-3">
                            <i class="fas fa-shopping-cart fa-2x mb-2 text-danger"></i>
                            <h6 class="fw-semibold text-white mb-1">Chi tiêu</h6>
                            <p class="fs-5 text-danger mb-0">@Model.TongChiTieu.ToString("N0") VNĐ</p>
                            <a asp-area="Admin" asp-controller="GiaoDich" asp-action="Index" class="btn btn-gold btn-sm rounded-pill px-2 py-1 mt-2 hover-shadow transition-all">
                                <i class="fas fa-list"></i>
                            </a>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4 col-md-6">
                    <div class="card mini-card shadow-lg border-0 hover-shadow animate-scale" style="background-color: #1e1e1e;">
                        <div class="card-body text-center p-3">
                            <i class="fas fa-piggy-bank fa-2x mb-2 @(Model.SoTienTietKiem >= 0 ? "text-success" : "text-danger")"></i>
                            <h6 class="fw-semibold text-white mb-1">Tiết kiệm</h6>
                            <p class="fs-5 @(Model.SoTienTietKiem >= 0 ? "text-success" : "text-danger") mb-0">@Model.SoTienTietKiem.ToString("N0") VNĐ</p>
                            <a asp-area="Admin" asp-controller="MucTieu" asp-action="Index" class="btn btn-gold btn-sm rounded-pill px-2 py-1 mt-2 hover-shadow transition-all">
                                <i class="fas fa-list"></i>
                            </a>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6 col-md-6">
                    <div class="card mini-card shadow-lg border-0 hover-shadow animate-scale" style="background-color: #1e1e1e;">
                        <div class="card-body text-center p-3">
                            <i class="fas fa-hand-holding-usd fa-2x mb-2 text-danger"></i>
                            <h6 class="fw-semibold text-white mb-1">Nợ phải trả</h6>
                            <p class="fs-5 text-danger mb-0">@Model.NoPhaiTra.ToString("N0") VNĐ</p>
                            <a asp-area="Admin" asp-controller="NoKhoanVay" asp-action="Index" class="btn btn-gold btn-sm rounded-pill px-2 py-1 mt-2 hover-shadow transition-all">
                                <i class="fas fa-list"></i>
                            </a>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6 col-md-6">
                    <div class="card mini-card shadow-lg border-0 hover-shadow animate-scale" style="background-color: #1e1e1e;">
                        <div class="card-body text-center p-3">
                            <i class="fas fa-chart-line fa-2x mb-2 @(Model.LoiNhuanDauTu >= 0 ? "text-success" : "text-danger")"></i>
                            <h6 class="fw-semibold text-white mb-1">Lợi nhuận đầu tư</h6>
                            <p class="fs-5 @(Model.LoiNhuanDauTu >= 0 ? "text-success" : "text-danger") mb-0">@Model.LoiNhuanDauTu.ToString("N0") VNĐ</p>
                            <a asp-controller="DauTu" asp-action="Index" class="btn btn-gold btn-sm rounded-pill px-2 py-1 mt-2 hover-shadow transition-all">
                                <i class="fas fa-list"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Biểu đồ -->
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <div class="card shadow-lg border-0 hover-shadow" style="background-color: #1e1e1e;">
                        <div class="card-header py-2 bg-gradient" style="background: linear-gradient(45deg, #2B2B2B, #3C3C3C);">
                            <h6 class="mb-0 text-gold fw-semibold"><i class="fas fa-chart-bar me-2"></i>Thu nhập vs Chi tiêu</h6>
                        </div>
                        <div class="card-body p-3">
                            <canvas id="thuChiChart" style="max-height: 250px;"></canvas>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card shadow-lg border-0 hover-shadow" style="background-color: #1e1e1e;">
                        <div class="card-header py-2 bg-gradient" style="background: linear-gradient(45deg, #2B2B2B, #3C3C3C);">
                            <h6 class="mb-0 text-gold fw-semibold"><i class="fas fa-lightbulb me-2"></i>Chi tiêu theo danh mục</h6>
                        </div>
                        <div class="card-body p-3">
                            @if (!string.IsNullOrEmpty(Model.DanhMucData) && Model.DanhMucData != "[]")
                            {
                                <canvas id="danhMucChart" style="max-height: 250px;"></canvas>
                            }
                            else
                            {
                                <p class="text-muted text-center"><i class="fas fa-exclamation-circle me-2"></i>Chưa có dữ liệu</p>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tiến độ mục tiêu -->
            <div class="card shadow-lg border-0 hover-shadow" style="background-color: #1e1e1e; color: #f0f0f0;">
                <div class="card-header py-2 bg-gradient" style="background: linear-gradient(45deg, #2B2B2B, #3C3C3C);">
                    <h6 class="mb-0 text-gold fw-semibold"><i class="fas fa-bullseye me-2"></i>Mục tiêu tháng @Model.Thang/@Model.Nam</h6>
                </div>
                <div class="card-body p-2 text-white">
                    @if (Model.TienDoMucTieu.Any())
                    {
                        <!-- Swiper Container -->
                        <div class="swiper-container">
                            <div class="swiper-wrapper">
                                @{
                                    var mucTieuList = Model.TienDoMucTieu.Take(10).ToList(); // Lấy 10 mục tiêu
                                    for (int i = 0; i < mucTieuList.Count; i += 2) // Chia thành từng cặp 2 mục tiêu mỗi slide
                                    {
                                        <div class="swiper-slide">
                                            <div class="row g-2">
                                                <div class="col-6">
                                                    <div class="card bg-dark border-gold shadow-sm hover-shadow transition-all p-2 rounded-3">
                                                        <div class="d-flex justify-content-between align-items-center">
                                                            <div>
                                                                <h6 class="text-gold fw-semibold mb-1 text-truncate"><i class="fas fa-flag-checkered me-1"></i>@mucTieuList[i].TenMucTieu</h6>
                                                                <p class="mb-0 text-white fs-sm"><i class="fas fa-chart-line me-1"></i><strong class="text-gold">@mucTieuList[i].TienDo.ToString("F0")%</strong></p>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                @if (i + 1 < mucTieuList.Count) // Kiểm tra nếu còn mục tiêu thứ hai trong cặp
                                                {
                                                    <div class="col-6">
                                                        <div class="card bg-dark border-gold shadow-sm hover-shadow transition-all p-2 rounded-3">
                                                            <div class="d-flex justify-content-between align-items-center">
                                                                <div>
                                                                    <h6 class="text-gold fw-semibold mb-1 text-truncate"><i class="fas fa-flag-checkered me-1"></i>@mucTieuList[i + 1].TenMucTieu</h6>
                                                                    <p class="mb-0 text-white fs-sm"><i class="fas fa-chart-line me-1"></i><strong class="text-gold">@mucTieuList[i + 1].TienDo.ToString("F0")%</strong></p>
                                                                </div>         
                                                            </div>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                            <!-- Nút điều hướng -->
                            <div class="swiper-button-prev"></div>
                            <div class="swiper-button-next"></div>
                            <!-- Thanh phân trang -->
                            <div class="swiper-pagination"></div>
                        </div>
                        <div class="text-center mt-2">
                            <a asp-controller="MucTieu" asp-action="Index" class="btn btn-gold btn-sm rounded-pill px-2 py-1 hover-shadow transition-all">
                                <i class="fas fa-list me-1"></i>Xem tất cả
                            </a>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center mb-0"><i class="fas fa-exclamation-circle me-1"></i>Chưa có mục tiêu</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/swiper/swiper-bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const thuChiData = @Html.Raw(Model.ThuChiData);
            const thuChiCtx = document.getElementById('thuChiChart').getContext('2d');
            new Chart(thuChiCtx, {
                type: 'bar',
                data: {
                    labels: ['Thu nhập', 'Chi tiêu'],
                    datasets: [{
                        label: 'Số tiền (VNĐ)',
                        data: [thuChiData.ThuNhap, thuChiData.ChiTieu],
                        backgroundColor: ['rgba(75, 192, 192, 0.6)', 'rgba(255, 99, 132, 0.6)'],
                        borderColor: ['rgba(75, 192, 192, 1)', 'rgba(255, 99, 132, 1)'],
                        borderWidth: 1
                    }]
                },
                options: {
                    scales: {
                        y: { beginAtZero: true, title: { display: true, text: 'Số tiền (VNĐ)' } }
                    },
                    plugins: { legend: { display: false } }
                }
            });

            const danhMucLabels = @Html.Raw(Model.DanhMucLabels);
            const danhMucData = @Html.Raw(Model.DanhMucData);
            const danhMucColors = @Html.Raw(Model.DanhMucColors);
            if (danhMucData.length > 0) {
                const danhMucCtx = document.getElementById('danhMucChart').getContext('2d');
                new Chart(danhMucCtx, {
                    type: 'pie',
                    data: {
                        labels: danhMucLabels,
                        datasets: [{
                            label: 'Chi tiêu (VNĐ)',
                            data: danhMucData,
                            backgroundColor: danhMucColors,
                            borderWidth: 1
                        }]
                    },
                    options: {
                        plugins: { legend: { position: 'top' } }
                    }
                });
            }

            // Khởi tạo Swiper cho Tiến độ mục tiêu
            const swiper = new Swiper('.swiper-container', {
                slidesPerView: 1,
                spaceBetween: 10,
                navigation: {
                    nextEl: '.swiper-button-next',
                    prevEl: '.swiper-button-prev',
                },
                pagination: {
                    el: '.swiper-pagination',
                    clickable: true,
                },
                loop: true, // Lặp lại slideshow
                autoplay: {
                    delay: 5000, // Tự động trượt sau 5 giây
                    disableOnInteraction: false,
                }
            });
        });
    </script>
}

<style>
    .btn-gold {
        background-color: #F0B90B;
        color: #1e1e1e;
        border: none;
    }

        .btn-gold:hover {
            background-color: #d9a00a;
            color: #1e1e1e;
        }

    .bg-gold {
        background-color: #F0B90B !important;
    }

    .hover-shadow:hover {
        box-shadow: 0 4px 15px rgba(240, 185, 11, 0.3);
        transition: all 0.3s ease;
    }

    .transition-all {
        transition: all 0.3s ease;
    }

    .dashboard-container {
        flex-wrap: nowrap;
    }

    .mini-card {
        height: 100%;
    }

    .animate-scale {
        transition: transform 0.3s ease;
    }

        .animate-scale:hover {
            transform: scale(1.05);
        }

    .progress {
        background-color: #3C3C3C;
        height: 8px;
    }

    .text-truncate {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .filter-sidebar::-webkit-scrollbar {
        width: 6px;
    }

    .filter-sidebar::-webkit-scrollbar-thumb {
        background-color: #F0B90B;
        border-radius: 3px;
    }

    .filter-sidebar::-webkit-scrollbar-track {
        background-color: #2B2B2B;
    }

    .border-gold {
        border-color: #F0B90B !important;
    }

    .rounded-3 {
        border-radius: 0.75rem !important;
    }

    .fs-sm {
        font-size: 0.875rem;
    }

    /* Swiper Styles */
    .swiper-container {
        width: 100%;
        height: 100%;
        padding: 10px 0;
    }

    .swiper-slide {
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .swiper-button-prev, .swiper-button-next {
        color: #F0B90B;
    }

    .swiper-pagination-bullet {
        background: #3C3C3C;
        opacity: 0.5;
    }

    .swiper-pagination-bullet-active {
        background: #F0B90B;
        opacity: 1;
    }
</style>

<!-- Thêm link CSS Swiper trong layout hoặc head -->
<link rel="stylesheet" href="https://unpkg.com/swiper/swiper-bundle.min.css" />