@model QLTCCN.Models.Data.ApplicationUser

<div class="container my-5">
    <h2 class="text-center fw-bold mb-5" style="color: #f0b90b;"><i class="fas fa-user-edit me-2"></i>Sửa thông tin người dùng</h2>

    <!-- Form sửa người dùng -->
    <div class="card shadow-lg border-0 hover-shadow" style="background-color: #1e1e1e; color: #f0f0f0;">
        <div class="card-header py-3 bg-gradient" style="background: linear-gradient(45deg, #2B2B2B, #3C3C3C);">
            <h4 class="mb-0 text-gold fw-semibold"><i class="fas fa-edit me-2"></i>Chỉnh sửa thông tin</h4>
        </div>
        <div class="card-body p-4">
            <form asp-action="Edit" method="post">
                <input type="hidden" name="id" value="@Model.Id" />
                <div class="form-group mb-3">
                    <label for="email" class="fw-semibold text-white mb-2">Email</label>
                    <input type="text" class="form-control bg-dark text-white border-gold rounded-pill px-3 py-2" value="@Model.Email" disabled />
                </div>
                <div class="form-group mb-3">
                    <label for="fullName" class="fw-semibold text-white mb-2">Họ và tên</label>
                    <input type="text" name="fullName" class="form-control bg-dark text-white border-gold rounded-pill px-3 py-2" value="@Model.FullName" required />
                </div>
                <div class="form-group mb-4">
                    <label class="fw-semibold text-white mb-2">Vai trò</label>
                    @foreach (var role in ViewBag.AllRoles)
                    {
                        <div class="form-check mb-2">
                            <input type="checkbox" name="selectedRoles" value="@role" @(ViewBag.Roles.Contains(role) ? "checked" : "") class="form-check-input" />
                            <label class="form-check-label text-white">@role</label>
                        </div>
                    }
                </div>
                <div class="d-flex justify-content-center gap-3">
                    <button type="submit" class="btn btn-gold rounded-pill px-4 py-2 fw-semibold hover-shadow transition-all">
                        <i class="fas fa-save me-2"></i>Lưu
                    </button>
                    <a asp-action="Index" class="btn btn-secondary rounded-pill px-4 py-2 fw-semibold hover-shadow transition-all">
                        <i class="fas fa-times me-2"></i>Hủy
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .btn-gold {
        background-color: #F0B90B;
        color: #1e1e1e;
        border: none;
    }

        .btn-gold:hover {
            background-color: #d9a00a;
            color: #1e1e1e;
        }

    .btn-secondary {
        background-color: #6c757d;
        color: #fff;
        border: none;
    }

        .btn-secondary:hover {
            background-color: #5a6268;
            color: #fff;
        }

    .border-gold {
        border-color: #F0B90B !important;
    }

    .text-gold {
        color: #F0B90B !important;
    }

    .hover-shadow:hover {
        box-shadow: 0 4px 15px rgba(240, 185, 11, 0.3);
        transition: box-shadow 0.3s ease;
    }

    .transition-all {
        transition: all 0.3s ease;
    }
</style>