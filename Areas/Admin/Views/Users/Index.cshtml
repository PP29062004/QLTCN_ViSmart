@model List<QLTCCN.Models.Data.ApplicationUser>

<div class="container my-5">
    <h2 class="text-center fw-bold mb-5" style="color: #f0b90b;"><i class="fas fa-users me-2"></i>Quản lý người dùng</h2>

    <!-- Bảng danh sách người dùng -->
    <div class="card shadow-lg border-0 hover-shadow" style="background-color: #1e1e1e; color: #f0f0f0;">
        <div class="card-header py-3 bg-gradient" style="background: linear-gradient(45deg, #2B2B2B, #3C3C3C);">
            <h4 class="mb-0 text-gold fw-semibold"><i class="fas fa-table me-2"></i>Danh sách người dùng</h4>
        </div>
        <div class="card-body p-4">
            @if (Model.Any())
            {
                <table class="table table-striped table-dark">
                    <thead>
                        <tr>
                            <th>Email</th>
                            <th>Họ và tên</th>
                            <th>Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td>@user.Email</td>
                                <td>@user.FullName</td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@user.Id" class="btn btn-gold btn-sm rounded-pill px-3 py-1 hover-shadow transition-all me-1">
                                        <i class="fas fa-info-circle me-1"></i>Chi tiết
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-warning btn-sm rounded-pill px-3 py-1 hover-shadow transition-all me-1">
                                        <i class="fas fa-edit me-1"></i>Sửa
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@user.Id" class="btn btn-danger btn-sm rounded-pill px-3 py-1 hover-shadow transition-all">
                                        <i class="fas fa-trash me-1"></i>Xóa
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted text-center"><i class="fas fa-exclamation-circle me-2"></i>Không có người dùng nào.</p>
            }
            <a href="http://localhost:5253/Admin/BaoCao" class="btn btn-outline-light shadow-sm px-1">
                <i class="fa-solid fa-arrow-left me-1"></i> Quay lại
            </a>
        </div>
    </div>
</div>

<style>
    .btn-gold {
        background-color: #F0B90B;
        color: #1e1e1e;
        border: none;
    }

        .btn-gold:hover {
            background-color: #d9a00a;
            color: #1e1e1e;
        }

    .btn-warning {
        background-color: #ffc107;
        color: #1e1e1e;
        border: none;
    }

        .btn-warning:hover {
            background-color: #e0a800;
            color: #1e1e1e;
        }

    .btn-danger {
        background-color: #dc3545;
        color: #fff;
        border: none;
    }

        .btn-danger:hover {
            background-color: #c82333;
            color: #fff;
        }

    .text-gold {
        color: #F0B90B !important;
    }

    .hover-shadow:hover {
        box-shadow: 0 4px 15px rgba(240, 185, 11, 0.3);
        transition: box-shadow 0.3s ease;
    }

    .transition-all {
        transition: all 0.3s ease;
    }
</style>