@model List<QLTCCN.Models.Data.NoKhoanVay>

<div class="container my-5">
    <h2 class="text-center fw-bold mb-5" style="color: #f0b90b;"><i class="fas fa-hand-holding-usd me-2"></i>Danh sách nợ/khoản vay (Admin)</h2>

    <!-- Bảng danh sách nợ/khoản vay -->
    <div class="card shadow-lg border-0 hover-shadow" style="background-color: #1e1e1e; color: #f0f0f0;">
        <div class="card-header py-3 bg-gradient" style="background: linear-gradient(45deg, #2B2B2B, #3C3C3C);">
            <h4 class="mb-0 text-gold fw-semibold"><i class="fas fa-table me-2"></i>Danh sách nợ/khoản vay</h4>
        </div>
        <div class="card-body p-4">
            @if (Model.Any())
            {
                <table class="table table-striped table-dark">
                    <thead>
                        <tr>
                            <th>Tên khoản vay</th>
                            <th>Số tiền</th>
                            <th>Lãi suất</th>
                            <th>Kỳ hạn</th>
                            <th>Ngày bắt đầu</th>
                            <th>Trạng thái</th>
                            <th>Người dùng</th>
                            <th>Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.GhiChu</td>
                                <td class="text-danger">@item.SoTien.ToString("N0") VNĐ</td>
                                <td>@item.LaiSuat%</td>
                                <td>@item.KyHan tháng</td>
                                <td>@item.NgayBatDau.ToString("dd/MM/yyyy")</td>
                                <td>@item.TrangThai</td>
                                <td>@item.NguoiDung?.FullName (@item.NguoiDung?.Email)</td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@item.MaNo" class="btn btn-gold btn-sm rounded-pill px-3 py-1 hover-shadow transition-all">
                                        <i class="fas fa-info-circle me-2"></i>Chi tiết
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted text-center"><i class="fas fa-exclamation-circle me-2"></i>Không có khoản vay nào.</p>
            }
            <a href="http://localhost:5253/Admin/BaoCao" class="btn btn-outline-light shadow-sm px-1">
                <i class="fa-solid fa-arrow-left me-1"></i> Quay lại
            </a>
        </div>
    </div>
</div>

<style>
    .btn-gold {
        background-color: #F0B90B;
        color: #1e1e1e;
        border: none;
    }

        .btn-gold:hover {
            background-color: #d9a00a;
            color: #1e1e1e;
        }

    .border-gold {
        border-color: #F0B90B !important;
    }

    .text-gold {
        color: #F0B90B !important;
    }

    .hover-shadow:hover {
        box-shadow: 0 4px 15px rgba(240, 185, 11, 0.3);
        transition: box-shadow 0.3s ease;
    }

    .transition-all {
        transition: all 0.3s ease;
    }
</style>