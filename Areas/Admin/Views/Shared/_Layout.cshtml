<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - QLTCCN</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
</head>
<body>
    <!-- Header -->
    <nav class="navbar navbar-expand-lg navbar-dark shadow-lg" style="background: linear-gradient(45deg, #1e1e1e, #2B2B2B);">
        <div class="container-fluid">
            <a class="navbar-brand text-gold fw-bold hover-shadow transition-all" asp-area="" asp-controller="Home" asp-action="Index">
                <i class="fas fa-wallet me-2"></i>Vi-Smart
            </a>
            <button class="navbar-toggler border-gold" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                <ul class="navbar-nav flex-grow-1">
                    <!-- Tỷ giá -->
                    <li class="nav-item">
                        <a class="nav-link text-white hover-gold transition-all" href="@Url.Action("Index", "TyGia")">
                            <i class="fas fa-exchange-alt me-2"></i>Tỷ giá
                        </a>
                    </li>

                    <!-- Mục tiêu -->
                    <li class="nav-item">
                        <a class="nav-link text-white hover-gold transition-all" href="@Url.Action("Index", "MucTieu")">
                            <i class="fas fa-bullseye me-2"></i>Mục tiêu
                        </a>
                    </li>

                    <!-- Danh mục -->
                    <li class="nav-item">
                        <a class="nav-link text-white hover-gold transition-all" href="@Url.Action("Index", "DanhMuc")">
                            <i class="fas fa-list-alt me-2"></i>Danh mục
                        </a>
                    </li>

                    <!-- Vay nợ -->
                    <li class="nav-item">
                        <a class="nav-link text-white hover-gold transition-all" href="@Url.Action("Index", "NoKhoanVay")">
                            <i class="fas fa-list-alt me-2"></i>Nợ/Khoản vay
                        </a>
                    </li>

                    <!-- Tài khoản giao dịch -->
                    <li class="nav-item dropdown">
                        <a class="nav-link text-white hover-gold transition-all dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                            <i class="fas fa-wallet me-2"></i>Thu chi
                        </a>
                        <ul class="dropdown-menu dropdown-menu-dark" style="background-color: #2B2B2B;">
                            <li><a class="dropdown-item text-white hover-gold transition-all" href="@Url.Action("Index", "TaiKhoan")">📋 Tài khoản</a></li>
                            <li><a class="dropdown-item text-white hover-gold transition-all" href="@Url.Action("Index", "QuanLyGiaoDich")">💸 Danh sách giao dịch</a></li>
                        </ul>
                    </li>

                    @* <!-- Nợ/Khoản vay --> *@
                    @* <li class="nav-item dropdown"> *@
                    @*     <a class="nav-link text-white hover-gold transition-all dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown"> *@
                    @*         <i class="fas fa-hand-holding-usd me-2"></i>Nợ/Khoản vay *@
                    @*     </a> *@
                    @*     <ul class="dropdown-menu dropdown-menu-dark" style="background-color: #2B2B2B;"> *@
                    @*         <li><a class="dropdown-item text-white hover-gold transition-all" href="@Url.Action("Index", "NoKhoanVay")">📋 Danh sách nợ</a></li> *@
                    @*         <li><a class="dropdown-item text-white hover-gold transition-all" href="@Url.Action("LichTraNo", "NoKhoanVay")">🗓️ Lịch trả nợ</a></li> *@
                    @*         <li><hr class="dropdown-divider" style="border-color: #F0B90B;"></li> *@
                    @*         <li><a class="dropdown-item text-white hover-gold transition-all" href="@Url.Action("KhoanVayCaNhan", "NoKhoanVay")">👤 Khoản vay cá nhân</a></li> *@
                    @*         <li><a class="dropdown-item text-white hover-gold transition-all" href="@Url.Action("NguoiChoVay", "NoKhoanVay")">🤝 Người cho vay</a></li> *@
                    @*     </ul> *@
                    @* </li> *@

                    <!-- Đầu tư -->
                    <li class="nav-item dropdown">
                        <a class="nav-link text-white hover-gold transition-all dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                            <i class="fas fa-chart-line me-2"></i>Đầu tư
                        </a>
                        <ul class="dropdown-menu dropdown-menu-dark" style="background-color: #2B2B2B;">
                            <li><a class="dropdown-item text-white hover-gold transition-all" href="@Url.Action("Index", "DauTu")">📈 Danh sách đầu tư</a></li>
                            <li><a class="dropdown-item text-white hover-gold transition-all" href="@Url.Action("Index", "LoaiDauTu")">📊 Loại đầu tư</a></li>
                        </ul>
                    </li>

                    @* <!-- Báo cáo --> *@
                    @* <li class="nav-item"> *@
                    @*     <a class="nav-link text-white hover-gold transition-all" href="@Url.Action("Index", "BaoCao")"> *@
                    @*         <i class="fas fa-chart-bar me-2"></i>Báo cáo *@
                    @*     </a> *@
                    @* </li> *@
                </ul>

                <!-- Báo cáo -->
                <li class="nav-item navbar-nav mr-auto">
                    <a class="nav-link text-white hover-gold transition-all" href="@Url.Action("Index", "BaoCao")">
                        <i class="fas fa-chart-bar me-2"></i>Báo cáo
                    </a>
                </li>

                <!-- Thông báo -->
                <ul class="navbar-nav mr-auto">
                    @await Html.PartialAsync("_ThongBaoPartial")
                </ul>

                <ul class="navbar-nav mr-auto">
                    <li class="nav-item">
                        <span class="nav-link text-gold">|</span>
                    </li>
                </ul>

                <!-- Tài khoản người dùng -->
                <ul class="navbar-nav">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link text-white hover-gold transition-all dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="fas fa-user-circle me-2"></i>Xin chào, @User.Identity.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end dropdown-menu-dark" style="background-color: #2B2B2B;">
                                @if (User.IsInRole("Admin"))
                                {
                                    <li class="nav-item">
                                        <a class="dropdown-item text-white hover-gold transition-all" asp-area="Admin" asp-controller="BaoCao" asp-action="Index">🔐 Quản trị</a>
                                    </li>
                                }
                                @* <li><a class="dropdown-item text-white hover-gold transition-all" asp-controller="Account" asp-action="Profile">🔐 Hồ sơ cá nhân</a></li> *@
                                <li><a class="dropdown-item text-white hover-gold transition-all" href="https://dylannquyen.github.io/CV/">🧑‍💼 Hồ sơ cá nhân</a></li>
                                <li><a class="dropdown-item text-white hover-gold transition-all" asp-controller="Account" asp-action="ChangePassword">🔑 Đổi mật khẩu</a></li>
                                <li><hr class="dropdown-divider" style="border-color: #F0B90B;"></li>
                                <li>
                                    <form id="logoutForm" asp-controller="Account" asp-action="Logout" method="post" class="m-0 p-0">
                                        <a href="#" class="dropdown-item text-white hover-gold transition-all" onclick="document.getElementById('logoutForm').submit(); return false;">
                                            <i class="fas fa-sign-out-alt me-2"></i>Đăng xuất
                                        </a>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link text-white hover-gold transition-all dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="fas fa-user me-2"></i>Tài khoản
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end dropdown-menu-dark" style="background-color: #2B2B2B;">
                                <li><a class="dropdown-item text-white hover-gold transition-all" asp-controller="Account" asp-action="Login">🧑 Đăng nhập</a></li>
                                <li><a class="dropdown-item text-white hover-gold transition-all" asp-controller="Account" asp-action="Register">✍️ Đăng ký</a></li>
                            </ul>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- Footer -->
    <footer class="footer text-center">
        <div class="container py-4">
            <div class="row">
                <div class="col-md-4">
                    <h5>Vi-Smart</h5>
                    <p>Ứng dụng quản lý tài chính cá nhân hàng đầu tại Việt Nam.</p>
                </div>
                <div class="col-md-4">
                    <h5>Liên kết</h5>
                    <p>
                        <a href="#">Chính sách</a> | <a href="#">Liên hệ</a> | <a href="#">Đối tác</a>
                    </p>
                </div>
                <div class="col-md-4">
                    <h5>Đối tác & Giải thưởng</h5>
                    <p>Đối tác: VNPay, Techcombank<br>Giải thưởng: FinTech 2024</p>
                </div>
            </div>
            <p class="mt-3">© 2025 - QLTCCN - All Rights Reserved</p>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.11/jquery.validate.unobtrusive.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
<style>
    /* Hiệu ứng hover cho các liên kết */
    .hover-gold:hover {
        color: #F0B90B !important;
        transition: color 0.3s ease;
    }

    /* Tùy chỉnh dropdown menu */
    .dropdown-menu {
        border: 1px solid #F0B90B;
        border-radius: 8px;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
    }

    .dropdown-item:hover {
        background-color: #3C3C3C !important;
        color: #F0B90B !important;
        transition: background-color 0.3s ease, color 0.3s ease;
    }

    /* Tùy chỉnh navbar toggler */
    .navbar-toggler {
        border-color: #F0B90B !important;
    }

    .navbar-toggler-icon {
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 30'%3e%3cpath stroke='rgba(240, 185, 11, 1)' stroke-linecap='round' stroke-miterlimit='10' stroke-width='2' d='M4 7h22M4 15h22M4 23h22'/%3e%3c/svg%3e");
    }
</style>
</html>