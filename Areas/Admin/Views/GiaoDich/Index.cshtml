@model List<QLTCCN.Models.Data.GiaoDich>

<div class="container my-5">
    <h2 class="text-center fw-bold mb-5" style="color: #f0b90b;"><i class="fas fa-list-alt me-2"></i>Danh sách giao dịch (Admin)</h2>

    @if (Model.Any())
    {
        <!-- Bảng danh sách giao dịch -->
        <div class="card shadow-lg border-0 hover-shadow" style="background-color: #1e1e1e; color: #f0f0f0;">
            <div class="card-header py-3 bg-gradient" style="background: linear-gradient(45deg, #2B2B2B, #3C3C3C);">
                <h4 class="mb-0 text-gold fw-semibold"><i class="fas fa-table me-2"></i>Danh sách giao dịch</h4>
            </div>
            <div class="card-body p-4">
                <table class="table table-striped table-dark">
                    <thead>
                        <tr>
                            <th>Ngày giao dịch</th>
                            <th>Loại giao dịch</th>
                            <th>Số tiền</th>
                            <th>Danh mục</th>
                            <th>Tài khoản</th>
                            <th>Người dùng</th>
                            <th>Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.NgayGiaoDich.ToString("dd/MM/yyyy")</td>
                                <td>@item.LoaiGiaoDich</td>
                                <td class="@(item.SoTien >= 0 ? "text-success" : "text-danger")">@item.SoTien.ToString("N0") VNĐ</td>
                                <td>@item.DanhMuc?.TenDanhMuc</td>
                                <td>@item.TaiKhoan?.TenTaiKhoan</td>
                                <td>@item.NguoiDung?.FullName (@item.NguoiDung?.Email)</td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@item.MaGiaoDich" class="btn btn-gold btn-sm rounded-pill px-3 py-1 hover-shadow transition-all">
                                        <i class="fas fa-info-circle me-2"></i>Chi tiết
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <p class="text-muted text-center"><i class="fas fa-exclamation-circle me-2"></i>Không có giao dịch nào.</p>
    }
    <a href="http://localhost:5253/Admin/BaoCao" class="btn btn-outline-light shadow-sm px-1">
        <i class="fa-solid fa-arrow-left me-1"></i> Quay lại
    </a>
</div>

<style>
    .btn-gold {
        background-color: #F0B90B;
        color: #1e1e1e;
        border: none;
    }

        .btn-gold:hover {
            background-color: #d9a00a;
            color: #1e1e1e;
        }

    .border-gold {
        border-color: #F0B90B !important;
    }

    .text-gold {
        color: #F0B90B !important;
    }

    .hover-shadow:hover {
        box-shadow: 0 4px 15px rgba(240, 185, 11, 0.3);
        transition: box-shadow 0.3s ease;
    }

    .transition-all {
        transition: all 0.3s ease;
    }
</style>