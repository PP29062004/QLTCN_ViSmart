@model List<QLTCCN.Models.Data.DauTu>

<div class="container my-5">
    <h2 class="text-center fw-bold mb-5" style="color: #f0b90b;"><i class="fas fa-chart-line me-2"></i>Danh sách đầu tư (Admin)</h2>

    <!-- Form bộ lọc -->
    <div class="card mb-5 shadow-lg border-0 hover-shadow" style="background-color: #1e1e1e; color: #f0f0f0;">
        <div class="card-header py-3 bg-gradient" style="background: linear-gradient(45deg, #2B2B2B, #3C3C3C);">
            <h4 class="mb-0 text-gold fw-semibold"><i class="fas fa-filter me-2"></i>Bộ lọc</h4>
        </div>
        <div class="card-body p-4">
            <form asp-action="Index" method="get" class="d-flex align-items-end gap-4 flex-wrap justify-content-center">
                <div class="form-group" style="min-width: 200px;">
                    <label for="startDate" class="fw-semibold text-white mb-2">Từ ngày</label>
                    <input type="date" name="startDate" id="startDate" class="form-control bg-dark text-white border-gold rounded-pill px-3 py-2 shadow-sm transition-all" value="@ViewBag.StartDate" />
                </div>
                <div class="form-group" style="min-width: 200px;">
                    <label for="endDate" class="fw-semibold text-white mb-2">Đến ngày</label>
                    <input type="date" name="endDate" id="endDate" class="form-control bg-dark text-white border-gold rounded-pill px-3 py-2 shadow-sm transition-all" value="@ViewBag.EndDate" />
                </div>
                <div class="form-group" style="min-width: 200px;">
                    <label for="maLoaiDauTu" class="fw-semibold text-white mb-2">Loại đầu tư</label>
                    <select name="maLoaiDauTu" id="maLoaiDauTu" class="form-select bg-dark text-white border-gold rounded-pill px-3 py-2 shadow-sm transition-all">
                        <option value="">Tất cả</option>
                        @if (ViewBag.LoaiDauTuList != null)
                        {
                            foreach (var item in ViewBag.LoaiDauTuList as SelectList)
                            {
                                <option value="@item.Value" selected="@(item.Value == ViewBag.MaLoaiDauTu?.ToString() ? "selected" : null)">@item.Text</option>
                            }
                        }
                    </select>
                </div>
                <div class="form-group">
                    <button type="submit" class="btn btn-gold rounded-pill px-4 py-2 fw-semibold hover-shadow transition-all">
                        <i class="fas fa-filter me-2"></i>Lọc
                    </button>
                </div>
                <div class="form-group">
                    <a asp-action="Index" class="btn btn-secondary rounded-pill px-4 py-2 fw-semibold hover-shadow transition-all">
                        <i class="fas fa-times me-2"></i>Xóa bộ lọc
                    </a>
                </div>
            </form>
        </div>
    </div>

    <!-- Biểu đồ lợi nhuận -->
    <div class="card mb-5 shadow-lg border-0 hover-shadow" style="background-color: #1e1e1e;">
        <div class="card-header py-3 bg-gradient" style="background: linear-gradient(45deg, #2B2B2B, #3C3C3C);">
            <h4 class="mb-0 text-gold fw-semibold"><i class="fas fa-chart-line me-2"></i>Biểu đồ lợi nhuận/lỗ</h4>
        </div>
        <div class="card-body p-4">
            @if (Model != null && Model.Any())
            {
                <canvas id="loiNhuanChart" style="max-height: 400px;"></canvas>
            }
            else
            {
                <p class="text-muted text-center"><i class="fas fa-exclamation-circle me-2"></i>Chưa có khoản đầu tư nào để hiển thị biểu đồ.</p>
            }
        </div>
    </div>

    <!-- Danh sách đầu tư -->
    <div class="card shadow-lg border-0 hover-shadow" style="background-color: #1e1e1e; color: #f0f0f0;">
        <div class="card-header py-3 bg-gradient" style="background: linear-gradient(45deg, #2B2B2B, #3C3C3C);">
            <h4 class="mb-0 text-gold fw-semibold"><i class="fas fa-table me-2"></i>Danh sách đầu tư</h4>
        </div>
        <div class="card-body p-4">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-dark">
                        <thead>
                            <tr>
                                <th>Loại đầu tư</th>
                                <th>Giá trị ban đầu</th>
                                <th>Giá trị hiện tại</th>
                                <th>Lợi nhuận/Lỗ</th>
                                <th>Ngày đầu tư</th>
                                <th>Ngày kết thúc</th>
                                <th>Trạng thái</th>
                                <th>Người dùng</th>
                                <th>Ghi chú</th>
                                @* <th>Hành động</th> *@
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@(item.LoaiDauTu?.TenLoai ?? "N/A")</td>
                                    <td>@item.GiaTri.ToString("N0") VNĐ</td>
                                    <td>@item.GiaTriHienTai.ToString("N0") VNĐ</td>
                                    <td>
                                        @{
                                            var loiNhuan = item.GiaTriHienTai - item.GiaTri;
                                            var mau = loiNhuan >= 0 ? "text-success" : "text-danger";
                                        }
                                        <span class="@mau">@loiNhuan.ToString("N0") VNĐ</span>
                                    </td>
                                    <td>@item.Ngay.ToString("dd/MM/yyyy")</td>
                                    <td>@(item.NgayKetThuc.HasValue ? item.NgayKetThuc.Value.ToString("dd/MM/yyyy") : "Chưa kết thúc")</td>
                                    <td>@item.TrangThai</td>
                                    <td>@(item.NguoiDung?.FullName ?? "N/A") (@(item.NguoiDung?.Email ?? "N/A"))</td>
                                    <td>@item.GhiChu</td>
                                    @* <td> *@
                                    @*     <a asp-action="Details" asp-route-id="@item.MaDauTu" class="btn btn-gold btn-sm rounded-pill px-3 py-1 hover-shadow transition-all"> *@
                                    @*         <i class="fas fa-info-circle"></i> *@
                                    @*     </a> *@
                                    @* </td> *@
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted text-center"><i class="fas fa-exclamation-circle me-2"></i>Không có khoản đầu tư nào.</p>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const labels = @Html.Raw(ViewBag.Labels ?? "[]");
            const loiNhuanData = @Html.Raw(ViewBag.LoiNhuanData ?? "[]");
            const colors = @Html.Raw(ViewBag.Colors ?? "[]");

            if (labels.length > 0 && loiNhuanData.length > 0) {
                const ctx = document.getElementById('loiNhuanChart').getContext('2d');
                new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: 'Lợi nhuận/Lỗ - VNĐ',
                            data: loiNhuanData,
                            backgroundColor: colors,
                            borderColor: colors.map(color => color.replace('0.6', '1')),
                            borderWidth: 1
                        }]
                    },
                    options: {
                        scales: {
                            y: {
                                beginAtZero: true,
                                title: { display: true, text: 'Lợi nhuận/Lỗ - VNĐ' }
                            },
                            x: {
                                title: { display: true, text: 'Khoản đầu tư' }
                            }
                        },
                        plugins: {
                            legend: { display: true, position: 'top' }
                        }
                    }
                });
            }
        });
    </script>
}

<style>
    .btn-gold {
        background-color: #F0B90B;
        color: #1e1e1e;
        border: none;
    }

        .btn-gold:hover {
            background-color: #d9a00a;
            color: #1e1e1e;
        }

    .btn-secondary {
        background-color: #6c757d;
        color: #fff;
        border: none;
    }

        .btn-secondary:hover {
            background-color: #5a6268;
            color: #fff;
        }

    .border-gold {
        border-color: #F0B90B !important;
    }

    .text-gold {
        color: #F0B90B !important;
    }

    .hover-shadow:hover {
        box-shadow: 0 4px 15px rgba(240, 185, 11, 0.3);
        transition: all 0.3s ease;
    }

    .transition-all {
        transition: all 0.3s ease;
    }
</style>