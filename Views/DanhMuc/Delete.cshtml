@model QLTCCN.Models.Data.DanhMuc

@{
    ViewData["Title"] = "Xóa danh mục";
}

<div class="container py-5">
    <div class="card shadow-lg border-0 hover-shadow" style="background-color: #1e1e1e; color: #f0f0f0;">
        <div class="card-header py-3 bg-gradient" style="background: linear-gradient(45deg, #FF0000, #CC0000);">
            <h4 class="mb-0 text-white fw-semibold"><i class="fas fa-trash-alt me-2"></i>Xóa danh mục</h4>
        </div>
        <div class="card-body p-4">
            <h4 class="text-danger mb-4"><i class="fas fa-exclamation-triangle me-2"></i>Bạn có chắc muốn xóa danh mục này?</h4>
            <dl class="row pt-3 text-white">
                <dt class="col-sm-3">Tên danh mục:</dt>
                <dd class="col-sm-9 text-gold">@Model.TenDanhMuc</dd>
                <dt class="col-sm-3">Loại:</dt>
                <dd class="col-sm-9 text-gold">@Model.Loai</dd>
            </dl>
            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="MaDanhMuc" />
                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 py-2 hover-shadow transition-all">
                        <i class="fas fa-times me-2"></i>Hủy
                    </a>
                    <button type="submit" class="btn btn-danger rounded-pill px-4 py-2 fw-semibold hover-shadow transition-all">
                        <i class="fas fa-trash-alt me-2"></i>Xóa
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>