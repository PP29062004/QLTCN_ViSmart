@model QLTCCN.Models.Data.DanhMuc

@{
    ViewData["Title"] = "Sửa danh mục";
}

<div class="container py-5">
    <div class="card shadow-lg border-0 hover-shadow" style="background-color: #1e1e1e; color: #f0f0f0;">
        <div class="card-header py-3 bg-gradient" style="background: linear-gradient(45deg, #2B2B2B, #3C3C3C);">
            <h4 class="mb-0 text-gold fw-semibold"><i class="fas fa-edit me-2"></i>Sửa danh mục</h4>
        </div>
        <div class="card-body p-4">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="MaDanhMuc" />

                <div class="mb-4">
                    <label asp-for="TenDanhMuc" class="form-label fw-semibold text-white mb-2">Tên danh mục</label>
                    <input asp-for="TenDanhMuc" class="form-control bg-dark text-white border-gold rounded-pill px-3 py-2 shadow-sm transition-all" />
                    <span asp-validation-for="TenDanhMuc" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Loai" class="form-label fw-semibold text-white mb-2">Loại</label>
                    <select asp-for="Loai" class="form-select bg-dark text-white border-gold rounded-pill px-3 py-2 shadow-sm transition-all">
                        <option value="">-- Chọn loại --</option>
                        <option value="Thu" selected="@(Model.Loai == "Thu")">Thu</option>
                        <option value="Chi" selected="@(Model.Loai == "Chi")">Chi</option>
                    </select>
                    <span asp-validation-for="Loai" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 py-2 hover-shadow transition-all">
                        <i class="fas fa-arrow-left me-2"></i>Quay lại
                    </a>
                    <button type="submit" class="btn btn-gold rounded-pill px-4 py-2 fw-semibold hover-shadow transition-all">
                        <i class="fas fa-save me-2"></i>Cập nhật
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}