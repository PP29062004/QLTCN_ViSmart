@model QLTCCN.Models.Data.DauTu

@{
    ViewData["Title"] = "Sửa đầu tư";
}

<div class="container py-5">
    <div class="card shadow-lg border-0 hover-shadow" style="background-color: #1e1e1e; color: #f0f0f0;">
        <div class="card-header py-3 bg-gradient" style="background: linear-gradient(45deg, #2B2B2B, #3C3C3C);">
            <h4 class="mb-0 text-gold fw-semibold"><i class="fas fa-edit me-2"></i>Sửa đầu tư</h4>
        </div>
        <div class="card-body p-4">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="All" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="MaDauTu" />

                <div class="mb-4">
                    <label asp-for="MaLoaiDauTu" class="form-label fw-semibold text-white mb-2">Loại đầu tư</label>
                    <select asp-for="MaLoaiDauTu" class="form-select bg-dark text-white border-gold rounded-pill px-3 py-2 shadow-sm transition-all" asp-items="ViewBag.LoaiDauTu" required>
                        <option value="">Chọn loại đầu tư</option>
                    </select>
                    <span asp-validation-for="MaLoaiDauTu" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="GiaTri" class="form-label fw-semibold text-white mb-2">Giá trị ban đầu</label>
                    <input asp-for="GiaTri" class="form-control bg-dark text-white border-gold rounded-pill px-3 py-2 shadow-sm transition-all" type="number" step="0.01" required />
                    <span asp-validation-for="GiaTri" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="GiaTriHienTai" class="form-label fw-semibold text-white mb-2">Giá trị hiện tại</label>
                    <input asp-for="GiaTriHienTai" class="form-control bg-dark text-white border-gold rounded-pill px-3 py-2 shadow-sm transition-all" type="number" step="0.01" required />
                    <span asp-validation-for="GiaTriHienTai" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="NgayKetThuc" class="form-label fw-semibold text-white mb-2">Ngày kết thúc</label>
                    <input asp-for="NgayKetThuc" class="form-control bg-dark text-white border-gold rounded-pill px-3 py-2 shadow-sm transition-all" type="date" value="@(Model.NgayKetThuc.HasValue ? Model.NgayKetThuc.Value.ToString("yyyy-MM-dd") : "")" />
                    <span asp-validation-for="NgayKetThuc" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="GhiChu" class="form-label fw-semibold text-white mb-2">Ghi chú</label>
                    <input asp-for="GhiChu" class="form-control bg-dark text-white border-gold rounded-pill px-3 py-2 shadow-sm transition-all" />
                    <span asp-validation-for="GhiChu" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 py-2 hover-shadow transition-all">
                        <i class="fas fa-arrow-left me-2"></i>Quay lại
                    </a>
                    <button type="submit" class="btn btn-gold rounded-pill px-4 py-2 fw-semibold hover-shadow transition-all">
                        <i class="fas fa-save me-2"></i>Cập nhật
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}