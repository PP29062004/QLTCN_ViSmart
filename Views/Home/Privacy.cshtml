@{
    ViewData["Title"] = "Privacy of Vi-Smart";
}

<div class="container my-5">
    <h1 class="display-5 text-center text-gold mb-4">Về chúng tôi aka Vi-Smart</h1>
    <div class="row">
        <div class="col-lg-6">
            <div class="card shadow-lg">
                <div class="card-header">
                    <h4>Giới thiệu</h4>
                </div>
                <div class="card-body">
                    <p class="text-secondary">Vi-Smart là ứng dụng quản lý tài chính cá nhân hàng đầu tại Việt Nam, giúp bạn theo dõi thu chi, đầu tư và tiết kiệm một cách thông minh.</p>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card shadow-lg">
                <div class="card-header">
                    <h4>Giải thưởng</h4>
                </div>
                <div class="card-body">
                    <ul>
                        <li class="text-secondary">Giải thưởng FinTech xuất sắc 2024</li>
                        <li class="text-secondary">Top 10 ứng dụng tài chính tại TechFest 2023</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
    <div class="row mt-4">
        <div class="col-lg-6">
            <div class="card shadow-lg">
                <div class="card-header">
                    <h4>Đối tác</h4>
                </div>
                <div class="card-body">
                    <p class="text-secondary">Chúng tôi tự hào hợp tác với: VNPay, Techcombank, Vietcombank, và ShopeePay.</p>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card shadow-lg">
                <div class="card-header">
                    <h4>Liên hệ</h4>
                </div>
                <div class="card-body">
                    <p class="text-secondary">Email: support@vismart.vn</p>
                    <p class="text-secondary">Hotline: 1900-J97S</p>
                    <p class="text-secondary">Địa chỉ: 123 Đường Tài Chính, Quận 9, TP.HCM</p>
                </div>
            </div>
        </div>
    </div>
</div>