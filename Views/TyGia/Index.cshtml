@using QLTCCN.Services
<h2 class="text-gold mb-4">💱 Tỷ giá ngoại tệ</h2>
@if (ViewBag.Error != null)
{
    <div class="alert alert-danger shadow-sm">@ViewBag.Error</div>
}
else
{
    <div class="card bg-dark text-white shadow-lg rounded-4 border border-gold mb-4">
        <div class="card-header bg-gradient-gold text-gold rounded-top-4">
            <h4 class="mb-0">Tỷ giá so với <strong>@ViewBag.BaseCurrency</strong></h4>
        </div>
        <div class="card-body p-4">
            <form asp-action="Index" method="get" class="d-flex flex-wrap gap-2 align-items-center mb-4">
                <label for="baseCurrency" class="me-2 mb-0">💵 Chọn tiền tệ gốc:</label>
                <select name="baseCurrency" id="baseCurrency" class="form-select w-auto rounded-pill">
                    @foreach (var currency in ViewBag.Currencies)
                    {
                        <option value="@currency" selected="@(currency == ViewBag.BaseCurrency ? "selected" : null)">@currency</option>
                    }
                </select>
                <button type="submit" class="btn btn-warning rounded-pill px-4">Xem tỷ giá</button>
                <a asp-action="Convert" class="btn btn-success rounded-pill px-4">🔄 Chuyển đổi tiền tệ</a>
            </form>

            <div class="table-responsive">
                <table class="table table-dark table-hover table-bordered border-secondary rounded">
                    <thead class="table-gold text-center">
                        <tr>
                            <th>💲 Tiền tệ</th>
                            <th>💹 Tỷ giá (@ViewBag.BaseCurrency)</th>
                        </tr>
                    </thead>
                    <tbody class="text-center">
                        @foreach (var rate in ViewBag.Rates)
                        {
                            <tr>
                                <td>@rate.Key</td>
                                <td>@rate.Value.ToString("N4")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

