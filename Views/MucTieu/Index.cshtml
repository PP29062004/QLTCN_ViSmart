@model List<QLTCCN.Models.Data.MucTieu>

@{
    ViewData["Title"] = "Danh sách mục tiêu";
}

<div class="container py-4">
    <h2 class="text-gold fw-bold mb-4">🎯 Danh sách mục tiêu</h2>

    <div class="table-responsive shadow-sm rounded-4 overflow-hidden">
        <table class="table table-dark table-hover align-middle text-white mb-0">
            <thead class="bg-gradient-gold text-dark">
                <tr>
                    <th>Tên mục tiêu</th>
                    <th>Danh mục</th>
                    <th>Số tiền mục tiêu</th>
                    <th>Đã tiết kiệm</th>
                    <th>Hạn chót</th>
                    <th>Trạng thái</th>
                    <th>Tiến độ</th>
                    <th class="text-center">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var progress = item.SoTienMucTieu > 0 ? (item.SoTienHienTai / item.SoTienMucTieu) * 100 : 0;
                    var statusBadge = item.TrangThai switch
                    {
                        "HoanThanh" => "<span class='badge bg-success'><i class='bi bi-check-circle-fill'></i> Hoàn thành</span>",
                        "ThatBai" => "<span class='badge bg-danger'><i class='bi bi-x-circle-fill'></i> Thất bại</span>",
                        "DangTienHanh" => "<span class='badge bg-warning text-dark'><i class='bi bi-hourglass-split'></i> Đang làm</span>",
                        _ => "<span class='badge bg-secondary'>Không rõ</span>"
                    };
                    <tr>
                        <td class="fw-semibold">@item.TenMucTieu</td>
                        <td>@item.DanhMuc.TenDanhMuc</td>
                        <td class="text-info">@item.SoTienMucTieu.ToString("N0") đ</td>
                        <td class="text-pink">@item.SoTienHienTai.ToString("N0") đ</td>                
                        <td>@item.HanChot.ToString("dd/MM/yyyy")</td>
                        <td>@Html.Raw(statusBadge)</td>
                        <td style="min-width: 160px;">
                            <div class="progress rounded-pill" style="height: 14px;">
                                <div class="progress-bar bg-gradient-gold text-dark fw-bold"
                                     role="progressbar"
                                     style="width: @progress.ToString("F0")%;"
                                     aria-valuenow="@progress.ToString("F0")"
                                     aria-valuemin="0" aria-valuemax="100">
                                    @progress.ToString("F0")%
                                </div>
                            </div>
                        </td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.MaMucTieu" class="btn btn-sm btn-outline-warning me-1">
                                <i class="bi bi-pencil-square"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.MaMucTieu" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash-fill"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="mt-4 d-flex gap-3">
        <a asp-action="Progress" class="btn btn-gold rounded-pill shadow-sm px-4">
            <i class="bi bi-bar-chart-steps me-1"></i> Xem tiến độ tổng thể
        </a>
        <a asp-action="Create" class="btn btn-outline-light rounded-pill shadow-sm px-4">
            <i class="bi bi-plus-circle me-1"></i> Thêm mục tiêu mới
        </a>
    </div>
</div>
