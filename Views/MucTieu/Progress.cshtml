@model IEnumerable<QLTCCN.Models.Data.MucTieu>

@{
    ViewBag.Title = "Tiến độ mục tiêu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <h2 class="text-center text-gold mb-5">Hành trình tiết kiệm</h2>

    <div class="row">
        @foreach (var item in Model)
        {
            var percent = item.SoTienMucTieu > 0 ? (int)(item.SoTienHienTai * 100 / item.SoTienMucTieu) : 0;
            var journeySteps = percent / 20;
            <div class="col-md-6 mb-4">
                <div class="card bg-dark text-white shadow-sm p-4 rounded-4 border border-gold">
                    <div class="d-flex justify-content-between align-items-center flex-wrap">
                        <!-- Cột trái: thông tin -->
                        <div class="info" style="flex: 1 1 55%;">
                            <h5 class="text-gold">@item.TenMucTieu</h5>
                            <p class="mb-1">🎯 Mục tiêu: <strong>@item.SoTienMucTieu.ToString("N0") đ</strong></p>
                            <p class="mb-3">💰 Đã tiết kiệm: <strong>@item.SoTienHienTai.ToString("N0") đ</strong> (@percent%)</p>

                            <div class="progress rounded-pill" style="height: 10px;">
                                <div class="progress-bar bg-gold" role="progressbar" style="width: @percent%" aria-valuenow="@percent" aria-valuemin="0" aria-valuemax="100"></div>
                            </div> 
                        </div>

                        <!-- Cột phải: journey -->
                        <div class="journey d-flex align-items-center justify-content-end" style="flex: 1 1 40%;">
                            <span class="text-gold me-2">🚶‍♂️</span>
                            @for (int i = 1; i <= 5; i++)
                            {
                                if (i <= journeySteps)
                                {
                                    <span class="step active-step mx-1"></span>
                                }
                                else
                                {
                                    <span class="step mx-1"></span>
                                }
                            }
                            <span class="text-gold ms-2">🏁</span>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
