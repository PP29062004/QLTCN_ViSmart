@model QLTCCN.Models.Data.MucTieu

@{
    ViewData["Title"] = "Thêm mục tiêu mới";
}

<div class="container bg-dark text-white rounded p-4 shadow mt-4">
    <h2 class="mb-4 text-warning"><i class="bi bi-plus-circle-fill"></i> Thêm mục tiêu mới</h2>

    <form asp-action="Create" method="post">
        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <div class="form-group mb-3">
            <label asp-for="TenMucTieu">Tên mục tiêu</label>
            <input asp-for="TenMucTieu" class="form-control bg-secondary text-white border-0 rounded" required />
            <span asp-validation-for="TenMucTieu" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="SoTienMucTieu">Số tiền mục tiêu</label>
            <input asp-for="SoTienMucTieu" type="number" step="0.01" class="form-control bg-secondary text-white border-0 rounded" required />
            <span asp-validation-for="SoTienMucTieu" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="MaDanhMuc">Danh mục</label>
            <select asp-for="MaDanhMuc" asp-items="ViewBag.DanhMuc" class="form-control bg-secondary text-white border-0 rounded" required>
                <option value="">Chọn danh mục</option>
            </select>
            <span asp-validation-for="MaDanhMuc" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="HanChot">Hạn chót</label>
            <input asp-for="HanChot" type="date" class="form-control bg-secondary text-white border-0 rounded" required />
            <span asp-validation-for="HanChot" class="text-danger"></span>
        </div>

        <div class="form-group mb-4">
            <label asp-for="GhiChu">Ghi chú</label>
            <input asp-for="GhiChu" class="form-control bg-secondary text-white border-0 rounded" />
            <span asp-validation-for="GhiChu" class="text-danger"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-warning">
                <i class="bi bi-check-circle"></i> Thêm
            </button>
            <a asp-action="Index" class="btn btn-outline-light">
                <i class="bi bi-arrow-left-circle"></i> Quay lại
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
