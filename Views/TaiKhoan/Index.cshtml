@model IEnumerable<QLTCCN.Models.Data.TaiKhoan>

@{
    ViewData["Title"] = "Danh sách tài khoản";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-gold fw-bold"><i class="fas fa-wallet me-2"></i>Danh sách tài khoản</h2>
        <a asp-action="Create" class="btn btn-gold rounded-pill px-4 py-2 fw-semibold hover-shadow transition-all">
            <i class="fas fa-plus me-2"></i>Thêm tài khoản mới
        </a>
    </div>

    @if (ViewBag.SurvivalMode == true)
    {
        <div class="alert alert-warning rounded shadow-sm d-flex align-items-center">
            <i class="fas fa-exclamation-triangle me-2"></i>
            <div>
                <strong>Chế độ sinh tồn đang được kích hoạt!</strong><br />
                Số dư hiện tại của bạn thấp hơn ngưỡng cho phép. Hãy hạn chế chi tiêu cho đến kỳ lương tiếp theo.
            </div>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-hover table-dark rounded shadow-sm">
            <thead class="table-gold text-dark">
                <tr class="text-center">
                    <th>Tên tài khoản</th>
                    <th>Số dư</th>
                    <th>Loại tài khoản</th>
                    <th>Ngày tạo</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody class="text-white">
                @foreach (var item in Model)
                {
                    <tr class="transition-all">
                        <td>@item.TenTaiKhoan</td>
                        <td>@item.SoDu.ToString("C")</td>
                        <td>@item.LoaiTaiKhoan</td>
                        <td>@item.NgayTao.ToString("dd/MM/yyyy")</td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.MaTaiKhoan" class="btn btn-sm btn-outline-warning rounded-pill px-3 me-2 hover-shadow transition-all">
                                <i class="fas fa-edit"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.MaTaiKhoan" class="btn btn-sm btn-outline-danger rounded-pill px-3 hover-shadow transition-all">
                                <i class="fas fa-trash-alt"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    /* Đảm bảo header bảng có màu vàng Binance */
    .table-gold {
        background: linear-gradient(45deg, #F0B90B, #D9A602);
    }

    /* Đảm bảo các dòng trong bảng có hiệu ứng hover */
    .table-hover tbody tr:hover {
        background-color: #3C3C3C !important;
        transition: background-color 0.3s ease;
    }

    /* Đảm bảo viền giữa các ô trong bảng không làm rối mắt */
    .table {
        border-collapse: separate;
        border-spacing: 0;
    }

        .table th, .table td {
            border: 1px solid #3C3C3C;
            vertical-align: middle;
        }
</style>