@model QLTCCN.Models.Data.NoKhoanVay

@{
    ViewData["Title"] = "Sửa khoản nợ/vay";
}

<div class="container py-5">
    <div class="card shadow-lg border-0 hover-shadow" style="background-color: #1e1e1e; color: #f0f0f0;">
        <div class="card-header py-3 bg-gradient" style="background: linear-gradient(45deg, #2B2B2B, #3C3C3C);">
            <h4 class="mb-0 text-gold fw-semibold"><i class="fas fa-edit me-2"></i>Sửa khoản nợ/vay</h4>
        </div>
        <div class="card-body p-4">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="All" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="MaNo" />

                <div class="mb-4">
                    <label asp-for="SoTien" class="form-label fw-semibold text-white mb-2">Số tiền</label>
                    <input asp-for="SoTien" class="form-control bg-dark text-white border-gold rounded-pill px-3 py-2 shadow-sm transition-all" type="number" step="0.01" required />
                    <span asp-validation-for="SoTien" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="LaiSuat" class="form-label fw-semibold text-white mb-2">Lãi suất (%)</label>
                    <input asp-for="LaiSuat" class="form-control bg-dark text-white border-gold rounded-pill px-3 py-2 shadow-sm transition-all" type="number" step="0.01" />
                    <span asp-validation-for="LaiSuat" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="KyHan" class="form-label fw-semibold text-white mb-2">Kỳ hạn (tháng)</label>
                    <input asp-for="KyHan" class="form-control bg-dark text-white border-gold rounded-pill px-3 py-2 shadow-sm transition-all" type="number" required />
                    <span asp-validation-for="KyHan" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="NgayBatDau" class="form-label fw-semibold text-white mb-2">Ngày bắt đầu</label>
                    <input asp-for="NgayBatDau" class="form-control bg-dark text-white border-gold rounded-pill px-3 py-2 shadow-sm transition-all" type="date" value="@Model.NgayBatDau.ToString("yyyy-MM-dd")" required />
                    <span asp-validation-for="NgayBatDau" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="GhiChu" class="form-label fw-semibold text-white mb-2">Ghi chú</label>
                    <input asp-for="GhiChu" class="form-control bg-dark text-white border-gold rounded-pill px-3 py-2 shadow-sm transition-all" />
                    <span asp-validation-for="GhiChu" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 py-2 hover-shadow transition-all">
                        <i class="fas fa-arrow-left me-2"></i>Quay lại
                    </a>
                    <button type="submit" class="btn btn-gold rounded-pill px-4 py-2 fw-semibold hover-shadow transition-all">
                        <i class="fas fa-save me-2"></i>Cập nhật
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}