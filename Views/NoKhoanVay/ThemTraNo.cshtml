@model QLTCCN.Models.Data.LichSuTraNo

@{
    ViewData["Title"] = "Thêm lần trả nợ";
}

<div class="container py-5">
    <div class="card shadow-lg border-0 hover-shadow" style="background-color: #1e1e1e; color: #f0f0f0;">
        <div class="card-header py-3 bg-gradient" style="background: linear-gradient(45deg, #2B2B2B, #3C3C3C);">
            <h4 class="mb-0 text-gold fw-semibold"><i class="fas fa-money-bill-wave me-2"></i>Thêm lần trả nợ</h4>
        </div>
        <div class="card-body p-4">
            <form asp-action="ThemTraNo" method="post">
                <div asp-validation-summary="All" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="MaNo" />

                <div class="mb-4">
                    <label asp-for="SoTienTra" class="form-label fw-semibold text-white mb-2">Số tiền trả</label>
                    <input asp-for="SoTienTra" class="form-control bg-dark text-white border-gold rounded-pill px-3 py-2 shadow-sm transition-all" type="number" step="0.01" required />
                    <span asp-validation-for="SoTienTra" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="NgayTra" class="form-label fw-semibold text-white mb-2">Ngày trả</label>
                    <input asp-for="NgayTra" class="form-control bg-dark text-white border-gold rounded-pill px-3 py-2 shadow-sm transition-all" type="date" value="@Model.NgayTra.ToString("yyyy-MM-dd")" required />
                    <span asp-validation-for="NgayTra" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="GhiChu" class="form-label fw-semibold text-white mb-2">Ghi chú</label>
                    <input asp-for="GhiChu" class="form-control bg-dark text-white border-gold rounded-pill px-3 py-2 shadow-sm transition-all" />
                    <span asp-validation-for="GhiChu" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="LichSuTraNo" asp-route-id="@Model.MaNo" class="btn btn-outline-secondary rounded-pill px-4 py-2 hover-shadow transition-all">
                        <i class="fas fa-arrow-left me-2"></i>Quay lại
                    </a>
                    <button type="submit" class="btn btn-gold rounded-pill px-4 py-2 fw-semibold hover-shadow transition-all">
                        <i class="fas fa-check me-2"></i>Thêm
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}