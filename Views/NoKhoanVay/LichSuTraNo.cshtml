@model QLTCCN.Models.Data.NoKhoanVay

@{
    ViewData["Title"] = "Lịch sử trả nợ";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-gold fw-bold"><i class="fas fa-history me-2"></i>Lịch sử trả nợ</h2>
        <a asp-action="ThemTraNo" asp-route-id="@Model.MaNo" class="btn btn-gold rounded-pill px-4 py-2 fw-semibold hover-shadow transition-all">
            <i class="fas fa-plus me-2"></i>Thêm lần trả nợ
        </a>
    </div>

    <h4 class="text-white mb-4">Khoản nợ/vay: <span class="text-gold">@Model.SoTien.ToString("C")</span> (Lãi suất: <span class="text-gold">@Model.LaiSuat%</span>)</h4>

    <div class="table-responsive">
        <table class="table table-hover table-dark rounded shadow-sm">
            <thead class="table-gold text-dark">
                <tr class="text-center">
                    <th>Số tiền trả</th>
                    <th>Ngày trả</th>
                    <th>Ghi chú</th>
                </tr>
            </thead>
            <tbody class="text-white">
                @if (Model.LichSuTraNos != null && Model.LichSuTraNos.Any())
                {
                    foreach (var item in Model.LichSuTraNos)
                    {
                        <tr class="transition-all">
                            <td>@item.SoTienTra.ToString("C")</td>
                            <td>@item.NgayTra.ToString("dd/MM/yyyy")</td>
                            <td>@item.GhiChu</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="text-center text-muted"><i class="fas fa-exclamation-circle me-2"></i>Chưa có lịch sử trả nợ.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-start mt-4">
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 py-2 hover-shadow transition-all">
            <i class="fas fa-arrow-left me-2"></i>Quay lại
        </a>
    </div>
</div>

<style>
    /* Đảm bảo header bảng có màu vàng Binance */
    .table-gold {
        background: linear-gradient(45deg, #F0B90B, #D9A602);
    }

    /* Đảm bảo các dòng trong bảng có hiệu ứng hover */
    .table-hover tbody tr:hover {
        background-color: #3C3C3C !important;
        transition: background-color 0.3s ease;
    }

    /* Đảm bảo viền giữa các ô trong bảng không làm rối mắt */
    .table {
        border-collapse: separate;
        border-spacing: 0;
    }

        .table th, .table td {
            border: 1px solid #3C3C3C;
            vertical-align: middle;
        }
</style>